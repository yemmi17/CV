---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import ProjectsPage from "@/components/ProjectsPage.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/Layout.astro";
import { getPublishedProjects } from "@/utils/content";

const projects = await getPublishedProjects("ru");
const siteUrl = SITE.website.endsWith("/") ? SITE.website.slice(0, -1) : SITE.website;
const title = "Проекты";
const description = "Избранные инфраструктурные, automation и reliability-проекты Никиты Борисова.";
const intro =
  "Список практических инженерных работ вокруг инфраструктуры, автоматизации, observability и delivery-процессов.";
---

<Layout
  title={`${title} | ${SITE.title}`}
  description={description}
  lang="ru"
  canonicalURL={`${siteUrl}/ru/projects`}
  alternateLinks={[
    { href: `${siteUrl}/projects`, hreflang: "en" },
    { href: `${siteUrl}/ru/projects`, hreflang: "ru" },
    { href: `${siteUrl}/projects`, hreflang: "x-default" },
  ]}
>
  <Header />
  <ProjectsPage title={title} intro={intro} locale="ru" projects={projects} />
  <Footer />
</Layout>
