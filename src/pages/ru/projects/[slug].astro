---
import { render } from "astro:content";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/Layout.astro";
import { getAllPublishedProjects, getEntrySlug, type ProjectEntry } from "@/utils/content";

export async function getStaticPaths() {
  const projects = await getAllPublishedProjects();

  return projects
    .filter((project) => project.data.locale === "ru")
    .map((project) => ({
      params: { slug: getEntrySlug(project) },
      props: { project },
    }));
}

interface Props {
  project: ProjectEntry;
}

const { project } = Astro.props;
const { Content } = await render(project);
const slug = getEntrySlug(project);
const siteUrl = SITE.website.endsWith("/") ? SITE.website.slice(0, -1) : SITE.website;
---

<Layout
  title={`${project.data.title} | ${SITE.title}`}
  description={project.data.description}
  lang="ru"
  canonicalURL={`${siteUrl}/ru/projects/${slug}`}
  alternateLinks={[
    { href: `${siteUrl}/projects/${slug}`, hreflang: "en" },
    { href: `${siteUrl}/ru/projects/${slug}`, hreflang: "ru" },
    { href: `${siteUrl}/projects/${slug}`, hreflang: "x-default" },
  ]}
>
  <Header />
  <main id="main-content" class="home-shell page-shell">
    <article class="prose page-prose project-detail">
      <p class="status-pill"><span></span>Project</p>
      <h1>{project.data.title}</h1>
      <p>{project.data.description}</p>
      <div class="tag-list">{project.data.tags.map((tag) => <span>{tag}</span>)}</div>
      <Content />
    </article>
  </main>
  <Footer />
</Layout>
