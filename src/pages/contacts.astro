---
import ContactsPage from "@/components/ContactsPage.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE } from "@/config";
import { profileContent } from "@/data/profile";
import Layout from "@/layouts/Layout.astro";

const content = profileContent.en;
const siteUrl = SITE.website.endsWith("/") ? SITE.website.slice(0, -1) : SITE.website;
---

<Layout
  title={`${content.contactTitle} | ${content.siteTitle}`}
  description={content.contactDescription}
  lang="en"
  canonicalURL={`${siteUrl}/contacts`}
  alternateLinks={[
    { href: `${siteUrl}/contacts`, hreflang: "en" },
    { href: `${siteUrl}/ru/contacts`, hreflang: "ru" },
    { href: `${siteUrl}/contacts`, hreflang: "x-default" },
  ]}
>
  <Header />
  <ContactsPage content={content} />
  <Footer />
</Layout>
