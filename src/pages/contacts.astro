---
import { render } from "astro:content";
import ContactsPage from "@/components/ContactsPage.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE } from "@/config";
import { profileContent } from "@/data/profile";
import Layout from "@/layouts/Layout.astro";
import { getPageDocument } from "@/utils/content";

const content = profileContent.en;
const page = await getPageDocument("en", "contacts");
const { Content } = await render(page);
const siteUrl = SITE.website.endsWith("/") ? SITE.website.slice(0, -1) : SITE.website;
---

<Layout
  title={`${page.data.title} | ${content.siteTitle}`}
  description={page.data.description}
  lang="en"
  canonicalURL={`${siteUrl}/contacts`}
  alternateLinks={[
    { href: `${siteUrl}/contacts`, hreflang: "en" },
    { href: `${siteUrl}/ru/contacts`, hreflang: "ru" },
    { href: `${siteUrl}/contacts`, hreflang: "x-default" },
  ]}
>
  <Header />
  <ContactsPage title={page.data.title} locale="en" contacts={content.contacts}>
    <Content />
  </ContactsPage>
  <Footer />
</Layout>
