---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import ProjectsPage from "@/components/ProjectsPage.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/Layout.astro";
import { getPublishedProjects } from "@/utils/content";

const projects = await getPublishedProjects("en");
const siteUrl = SITE.website.endsWith("/") ? SITE.website.slice(0, -1) : SITE.website;
const title = "Projects";
const description =
  "Selected infrastructure, automation, and reliability projects by Nikita Borisov.";
const intro =
  "A focused list of practical engineering work around infrastructure, automation, observability, and delivery workflows.";
---

<Layout
  title={`${title} | ${SITE.title}`}
  description={description}
  lang="en"
  canonicalURL={`${siteUrl}/projects`}
  alternateLinks={[
    { href: `${siteUrl}/projects`, hreflang: "en" },
    { href: `${siteUrl}/ru/projects`, hreflang: "ru" },
    { href: `${siteUrl}/projects`, hreflang: "x-default" },
  ]}
>
  <Header />
  <ProjectsPage title={title} intro={intro} locale="en" projects={projects} />
  <Footer />
</Layout>
