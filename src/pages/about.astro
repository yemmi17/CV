---
import { render } from "astro:content";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/Layout.astro";
import { getPageDocument } from "@/utils/content";

const page = await getPageDocument("en", "about");
const { Content } = await render(page);
const siteUrl = SITE.website.endsWith("/") ? SITE.website.slice(0, -1) : SITE.website;
---

<Layout
  title={`${page.data.title} | ${SITE.title}`}
  description={page.data.description}
  lang="en"
  canonicalURL={`${siteUrl}/about`}
  alternateLinks={[
    { href: `${siteUrl}/about`, hreflang: "en" },
    { href: `${siteUrl}/ru/about`, hreflang: "ru" },
    { href: `${siteUrl}/about`, hreflang: "x-default" },
  ]}
>
  <Header />
  <main id="main-content" class="mx-auto w-full max-w-3xl px-4 pb-12">
    <section class="prose mt-8 mb-28 max-w-3xl prose-img:border-0">
      <h1>{page.data.title}</h1>
      <Content />
    </section>
  </main>
  <Footer />
</Layout>
