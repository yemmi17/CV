---
import type { Locale } from "@/data/profile";
import { getEntrySlug, type ProjectEntry } from "@/utils/content";

export interface Props {
  title: string;
  intro: string;
  locale: Locale;
  projects: ProjectEntry[];
}

const { title, intro, locale, projects } = Astro.props;
const projectBasePath = locale === "ru" ? "/ru/projects" : "/projects";
---

<main id="main-content" class="home-shell page-shell">
  <section class="page-hero" aria-labelledby="projects-title">
    <p class="status-pill"><span></span>Portfolio</p>
    <h1 id="projects-title">{title}</h1>
    <p>{intro}</p>
  </section>

  <section class="content-section" aria-label={title}>
    <div class="project-grid page-card-grid">
      {projects.map((project, index) => (
        <article class="project-card page-project-card">
          <span class="project-icon">{index + 1}</span>
          <div>
            <h2>{project.data.title}</h2>
            <p>{project.data.description}</p>
            <div class="tag-list">{project.data.tags.map((tag) => <span>{tag}</span>)}</div>
            <a class="text-link" href={`${projectBasePath}/${getEntrySlug(project)}`}>
              {locale === "ru" ? "Открыть проект" : "Open project"} -&gt;
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</main>
