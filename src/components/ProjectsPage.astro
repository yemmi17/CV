---
import type { ProfileContent } from "@/data/profile";

export interface Props {
  content: ProfileContent;
}

const { content } = Astro.props;
---

<main id="main-content" class="home-shell page-shell">
  <section class="page-hero" aria-labelledby="projects-title">
    <p class="status-pill"><span></span>{content.locale === "ru" ? "Portfolio" : "Portfolio"}</p>
    <h1 id="projects-title">{content.projectsPage.title}</h1>
    <p>{content.projectsPage.intro}</p>
  </section>

  <section class="content-section" aria-label={content.projectsPage.title}>
    <div class="project-grid page-card-grid">
      {content.projects.map((project, index) => (
        <article class="project-card page-project-card">
          <span class="project-icon">{index + 1}</span>
          <div>
            <h2>{project.title}</h2>
            <p>{project.description}</p>
            <div class="tag-list">{project.tags.map((tag) => <span>{tag}</span>)}</div>
            {
              project.href && (
                <a class="text-link" href={project.href}>
                  {content.locale === "ru" ? "Открыть проект" : "Open project"} -&gt;
                </a>
              )
            }
          </div>
        </article>
      ))}
    </div>
  </section>
</main>
