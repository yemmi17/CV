---
import IconGitHub from "@/assets/icons/IconGitHub.svg";
import IconLinkedin from "@/assets/icons/IconLinkedin.svg";
import IconMail from "@/assets/icons/IconMail.svg";
import IconTelegram from "@/assets/icons/IconTelegram.svg";
import type { ProfileContent } from "@/data/profile";

export interface Props {
  content: ProfileContent;
}

const { content } = Astro.props;
const isRu = content.locale === "ru";
const homePath = isRu ? "/ru" : "/";
const projectsHref = isRu ? "/ru/projects" : "/projects";
const blogHref = isRu ? "/ru/blog" : "/blog";
const contactsHref = isRu ? "/ru/contacts" : "/contacts";

const t = isRu
  ? {
      uptime: "Uptime 24/7",
      readBlog: "Читать блог",
      seeProjects: "Смотреть проекты",
      why: "О чем этот сайт",
      fresh: "Свежие статьи",
      allPosts: "Все статьи",
      projects: "Проекты",
      allProjects: "Все проекты",
      about: "Обо мне",
      contact: "Контакты",
      portraitAlt: "Портрет Nikita Borisov",
      status: "System Status",
      deployments: "Deployments",
      reliability: "Reliability",
      thisWeek: "+42 this week",
      slo: "SLO соблюдается",
      noPosts: "Постов пока нет",
      noPostsText: "Коллекция блога готова, но опубликованных статей еще нет.",
    }
  : {
      uptime: "Uptime 24/7",
      readBlog: "Read blog",
      seeProjects: "View projects",
      why: "What this site is about",
      fresh: "Fresh articles",
      allPosts: "All articles",
      projects: "Projects",
      allProjects: "All projects",
      about: "About me",
      contact: "Contacts",
      portraitAlt: "Portrait of Nikita Borisov",
      status: "System Status",
      deployments: "Deployments",
      reliability: "Reliability",
      thisWeek: "+42 this week",
      slo: "SLO is healthy",
      noPosts: "No posts yet",
      noPostsText: "The blog collection is ready, but there are no published articles yet.",
    };

const contacts = content.contacts.filter((contact) =>
  ["Email", "Telegram", "GitHub", "LinkedIn"].includes(contact.label)
);

const whyItems = content.homeSections.slice(0, 4);
const stats = isRu
  ? [
      ["Активные проекты", content.projects.length.toString(), "live", "в портфолио"],
      ["Публикации", "0", "ready", "коллекция настроена"],
      ["Контакты", contacts.length.toString(), "open", "каналы связи"],
      ["Опыт", "1.5+", "years", "в индустрии"],
    ]
  : [
      ["Active projects", content.projects.length.toString(), "live", "in portfolio"],
      ["Publications", "0", "ready", "collection configured"],
      ["Contacts", contacts.length.toString(), "open", "available channels"],
      ["Experience", "1.5+", "years", "in the industry"],
    ];

const contactIcon = (label: string) =>
  label === "GitHub"
    ? IconGitHub
    : label === "LinkedIn"
      ? IconLinkedin
      : label === "Telegram"
        ? IconTelegram
        : IconMail;
---

<main id="main-content" class="home-shell" data-layout="index" data-home-path={homePath}>
  <section class="hero-panel" aria-labelledby="hero-title">
    <div class="hero-copy">
      <p class="status-pill"><span></span>{t.uptime}</p>
      <h1 id="hero-title">
        SRE / DevOps
        <span>Engineer</span>
      </h1>
      <p class="hero-summary">{content.heroSummary}</p>
      <div class="hero-actions">
        <a class="primary-action" href={blogHref}><span>Blog</span>{t.readBlog}</a>
        <a class="secondary-action" href={projectsHref}><span>Ops</span>{t.seeProjects}</a>
      </div>
      <div class="hero-contact-line">
        {contacts.slice(0, 3).map((contact) => {
          const Icon = contactIcon(contact.label);
          return (
            <a href={contact.href}>
              <Icon class="inline-icon" />
              <span>{contact.text}</span>
            </a>
          );
        })}
      </div>
    </div>

    <div class="hero-orbit" aria-label={t.portraitAlt}>
      <div class="orbit-ring"></div>
      <img src="/avatar.jpg" alt={t.portraitAlt} />
      <div class="float-card status-float">
        <span class="mini-icon">OK</span>
        <strong>{t.status}</strong>
        <small>All systems <b>100%</b></small>
      </div>
      <div class="float-card deploy-float">
        <strong>{t.deployments}</strong>
        <div class="mini-bars">
          {[30, 52, 38, 64, 45, 76, 58, 84].map((height) => (
            <span style={`--h:${height}%`}></span>
          ))}
        </div>
        <small>{t.thisWeek}</small>
      </div>
      <div class="float-card reliability-float">
        <strong>{t.reliability}</strong>
        <b>100%</b>
        <small>{t.slo}</small>
      </div>
    </div>

    <aside class="hero-stats">
      {stats.map(([label, value, delta, caption]) => (
        <div class="stat-card">
          <span>{label}</span>
          <strong>{value}</strong>
          <em>{delta}</em>
          <small>{caption}</small>
        </div>
      ))}
    </aside>
  </section>

  <section class="why-section" aria-labelledby="why-title">
    <h2 id="why-title">{t.why}</h2>
    <div class="why-grid">
      {whyItems.map((item, index) => (
        <article class="why-item">
          <span>{index + 1}</span>
          <div>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="blog" class="content-section" aria-labelledby="blog-title">
    <div class="section-heading">
      <h2 id="blog-title">{t.fresh}</h2>
      <a href={blogHref}>{t.allPosts} -></a>
    </div>
    <article class="empty-panel">
      <h3>{t.noPosts}</h3>
      <p>{t.noPostsText}</p>
    </article>
  </section>

  <section id="projects" class="content-section" aria-labelledby="projects-title">
    <div class="section-heading">
      <h2 id="projects-title">{t.projects}</h2>
      <a href={projectsHref}>{t.allProjects} -></a>
    </div>
    <div class="project-grid">
      {content.projects.map((project, index) => (
        <article class="project-card">
          <span class="project-icon">{index + 1}</span>
          <div>
            <h3>{project.title}</h3>
            <p>{project.description}</p>
            <div class="tag-list">{project.tags.map((tag) => <span>{tag}</span>)}</div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="bottom-grid" aria-label={`${t.about} and ${t.contact}`}>
    <article class="about-panel">
      <span class="about-icon">NB</span>
      <div>
        <h2>{t.about}</h2>
        <p>{content.homeSections[0]?.body}</p>
      </div>
    </article>

    <article id="contact" class="contact-panel">
      <div class="section-heading">
        <h2>{t.contact}</h2>
        <a href={contactsHref}>{t.contact} -></a>
      </div>
      <div class="contact-links">
        {contacts.map((contact) => {
          const Icon = contactIcon(contact.label);
          return (
            <a href={contact.href}>
              <Icon class="contact-icon" />
              <span>{contact.text}</span>
            </a>
          );
        })}
      </div>
    </article>
  </section>
</main>

<script>
  document.addEventListener("astro:page-load", () => {
    const mainContent = document.querySelector("#main-content") as HTMLElement | null;
    const homePath = mainContent?.dataset?.homePath || "/";
    if (mainContent?.dataset?.layout) {
      sessionStorage.setItem("backUrl", homePath);
    }
  });
</script>
