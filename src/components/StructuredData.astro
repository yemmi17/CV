---
import { SITE } from "@/config";

export interface Props {
  type: "BlogPosting" | "Person" | "WebSite";
  data: any;
}

const { type, data } = Astro.props;

const siteUrl = SITE.website.endsWith("/") ? SITE.website.slice(0, -1) : SITE.website;
const profileUrl = SITE.profile || `${siteUrl}/about`;
const imageUrl = `${siteUrl}/${SITE.ogImage}`;

let structuredData = {};

if (type === "BlogPosting") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: data.title,
    description: data.description,
    author: {
      "@type": "Person",
      name: data.author || SITE.author,
      url: profileUrl,
    },
    datePublished: data.pubDatetime?.toISOString?.(),
    dateModified: data.modDatetime?.toISOString?.() || data.pubDatetime?.toISOString?.(),
    publisher: {
      "@type": "Person",
      name: SITE.author,
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": data.url,
    },
    image: data.ogImage || imageUrl,
    articleSection: data.tags?.[0] || "Portfolio",
    keywords: data.tags?.join(", ") || "",
    wordCount: data.wordCount,
    timeRequired: data.readingTime,
  };
} else if (type === "Person") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: SITE.author,
    url: siteUrl,
    image: imageUrl,
    jobTitle: data.jobTitle || "SRE/DevOps Engineer",
    description: data.description || SITE.desc,
    sameAs: data.sameAs || [],
  };
} else if (type === "WebSite") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE.title,
    url: siteUrl,
    description: data.description || SITE.desc,
    author: {
      "@type": "Person",
      name: SITE.author,
    },
  };
}
---

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(structuredData)}
/>
