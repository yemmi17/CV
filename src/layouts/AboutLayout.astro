---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE } from "@/config";
import Layout from "./Layout.astro";

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
  };
}

const { frontmatter } = Astro.props;
const isRussian = Astro.url.pathname === "/ru/about" || Astro.url.pathname.startsWith("/ru/about/");
const siteUrl = SITE.website.endsWith("/") ? SITE.website.slice(0, -1) : SITE.website;
const canonicalURL = isRussian ? `${siteUrl}/ru/about` : `${siteUrl}/about`;
const alternateLinks = [
  { href: `${siteUrl}/about`, hreflang: "en" },
  { href: `${siteUrl}/ru/about`, hreflang: "ru" },
  { href: `${siteUrl}/about`, hreflang: "x-default" },
];
---

<Layout
  title={`${frontmatter.title} | ${SITE.title}`}
  description={frontmatter.description}
  lang={isRussian ? "ru" : "en"}
  canonicalURL={canonicalURL}
  alternateLinks={alternateLinks}
>
  <Header />
  <main id="main-content" class="mx-auto w-full max-w-3xl px-4 pb-12">
    <slot />
  </main>
  <Footer />
</Layout>
